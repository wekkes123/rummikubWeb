{
  "name": "electron-react-python-app",
  "version": "1.0.0",
  "description": "An Electron app with React frontend and Python backend",
  "main": "main.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "package": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1"
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.example.electronreactpython",
    "directories": {
      "output": "dist"
    },
    "files": [
      "react-frontend/build/**/*",
      "main.js"
    ]
  }
}
